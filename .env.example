ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Optional: use bcrypt hash for production
# ADMIN_PASSWORD_HASH=$2a$10$...
# Optional: custom database path
# DATABASE_PATH=/path/to/skills.db
# Optional: port for the web server (default: 3000)
# PORT=3000
# Optional: webhook URL for proposal submissions (AI implementation pipeline)
# PROPOSAL_WEBHOOK_URL=https://your-webhook-url.example.com/endpoint
